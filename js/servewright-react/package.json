{
  "name": "@servewright/react",
  "version": "0.1.0",
  "description": "Servewright React renderer engine",
  "repository": {
    "type": "git",
    "url": "https://github.com/Servewright/servewright.git",
    "directory": "js/servewright-react"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
