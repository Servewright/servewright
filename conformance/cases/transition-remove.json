{
  "name": "transition remove patch",
  "initialView": {
    "servewrightVersion": "1.0",
    "schemaVersion": "0.1.0",
    "screen": "demo-form",
    "stateVersion": 0,
    "root": {
      "id": "fields-group",
      "type": "Group",
      "props": { "label": "Fields" },
      "children": [
        {
          "id": "email",
          "type": "TextInput",
          "props": { "label": "Email", "value": "" }
        },
        {
          "id": "username",
          "type": "TextInput",
          "props": { "label": "Username", "value": "" }
        }
      ]
    }
  },
  "transitions": [
    {
      "basedOn": 0,
      "stateVersion": 1,
      "patches": [{ "op": "remove", "target": "username" }]
    }
  ],
  "expect": { "contains": ["Email"], "notContains": ["Username"] }
}
