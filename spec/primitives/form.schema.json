{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servewright.io/spec/primitives/form.schema.json",
  "title": "Form",
  "description": "Formulaire sémantique. Porte les champs et définit la cible d'action (binding en phase ultérieure).",
  "type": "object",
  "required": ["id", "type", "props", "children"],
  "properties": {
    "id": { "type": "string" },
    "type": { "const": "Form" },
    "props": {
      "type": "object",
      "required": ["actionTarget"],
      "properties": {
        "actionTarget": {
          "type": "string",
          "description": "Identifiant stable du formulaire pour le routing d'actions."
        }
      },
      "additionalProperties": false
    },
    "children": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    }
  },
  "additionalProperties": false
}
