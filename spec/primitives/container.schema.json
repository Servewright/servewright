{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servewright.io/spec/primitives/container.schema.json",
  "title": "Container",
  "description": "Conteneur de mise en page sémantique. Le rendu concret (flex, grid…) est décidé côté client.",
  "type": "object",
  "required": ["id", "type", "props", "children"],
  "properties": {
    "id": { "type": "string" },
    "type": { "const": "Container" },
    "props": {
      "type": "object",
      "properties": {
        "layout": {
          "type": "string",
          "enum": ["vertical", "horizontal"],
          "default": "vertical"
        }
      },
      "additionalProperties": false
    },
    "children": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    }
  },
  "additionalProperties": false
}
