{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servewright.io/spec/primitives/table.schema.json",
  "title": "Table",
  "description": "Tableau de données en lecture seule.",
  "type": "object",
  "required": ["id", "type", "props"],
  "properties": {
    "id": { "type": "string" },
    "type": { "const": "Table" },
    "props": {
      "type": "object",
      "required": ["columns", "rows"],
      "properties": {
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["key", "label"],
            "properties": {
              "key": { "type": "string" },
              "label": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["cells"],
            "properties": {
              "cells": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
