{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servewright.io/spec/primitives/text-input.schema.json",
  "title": "TextInput",
  "description": "Champ de saisie texte. Phase 2 : rendu inerte (valeur affichée, pas de binding actif).",
  "type": "object",
  "required": ["id", "type", "props"],
  "properties": {
    "id": { "type": "string" },
    "type": { "const": "TextInput" },
    "props": {
      "type": "object",
      "required": ["label"],
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" },
        "placeholder": { "type": "string" },
        "required": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
